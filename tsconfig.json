{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    // Resolve sibling packages from source during development.
    // Without this, tsc resolves from node_modules where the published
    // dist/ may be stale or missing. Vite handles this via its own
    // resolution, but tsc --noEmit needs explicit paths.
    "paths": {
      "@react-router-modules/core": ["./packages/core/src/index.ts"],
      "@react-router-modules/runtime": ["./packages/runtime/src/index.ts"],
      "@react-router-modules/testing": ["./packages/testing/src/index.ts"]
    }
  },
  "include": ["packages/core/src", "packages/runtime/src", "packages/testing/src"]
}
